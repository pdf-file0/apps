node_modules/
dist/
coverage/
.env
*.log

# Run outputs are generated artifacts
runs/*
!runs/.gitkeep

# Local browser profile for live recon — may contain cookies/session data,
# must never be committed
.browser-profile/

# Real candidate profile/answers and generated application packets contain
# PII — local only, never committed. Committed counterparts are the
# *.example.yaml files and test fixtures with dummy data.
profiles/*.local.yaml
packets/
flows/

# Local document manifest declares real CV contents (emails, deal figures) —
# local only, never committed. Committed counterpart is the *.example.yaml.
config/*.local.yaml

# Never commit real candidate documents
documents/*
!documents/.gitkeep
