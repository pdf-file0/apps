# job-apply-agent environment template
#
# Phase 1 needs NO environment variables: everything runs offline from
# config files and local fixtures.
#
# The keys below are placeholders for Phase 2 (content fetching / browser
# automation). Copy this file to .env and fill values there — .env is
# gitignored. NEVER commit real API keys, passwords, OTPs, cookies, or any
# credentials to this repository.

# Phase 2: Firecrawl content provider (not used in Phase 1)
FIRECRAWL_API_KEY=

# Phase 2: Playwright browser automation (not used in Phase 1)
PLAYWRIGHT_HEADLESS=true
