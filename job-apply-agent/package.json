{
  "name": "job-apply-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Phase 1: offline job classification and CV routing. Never submits applications, never creates accounts, never uploads documents.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "classify": "tsx src/index.ts",
    "recon": "tsx src/recon.ts",
    "recon:fixture": "tsx src/recon.ts --provider fixture",
    "profile:validate": "tsx src/profile-cli.ts validate",
    "profile:summary": "tsx src/profile-cli.ts summary",
    "packet": "tsx src/packet-cli.ts",
    "flow:map": "tsx src/flow-cli.ts",
    "documents:validate": "tsx src/document-cli.ts validate",
    "documents:readiness": "tsx src/document-cli.ts readiness",
    "accounts:list": "tsx src/account-cli.ts list",
    "accounts:plan": "tsx src/account-cli.ts plan",
    "accounts:setup": "tsx src/account-cli.ts setup",
    "accounts:record": "tsx src/account-cli.ts record",
    "draft:workday": "tsx src/draft-cli.ts"
  },
  "dependencies": {
    "playwright-core": "^1.49.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
